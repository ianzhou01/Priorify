{
  "manifest_version": 3,
  "name": "Priorify",
  "description": "A lightweight task prioritization assistant.",
  "version": "1.0",

  "action": {
    "default_popup": "src/popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "background": {
    "service_worker": "src/background.js"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "windows"
  ],
  
  "web_accessible_resources": [
    {
      "resources": [
        "src/taskcard.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}