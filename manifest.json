{
  "manifest_version": 3,
  "name": "Priorify",
  "description": "A lightweight task prioritization assistant.",
  "version": "1.3",

  "action": {
    "default_popup": "src/popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/config.js", "src/background.js"]
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "windows",
    "tabs"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "priorify@extension",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "src/taskcard.html",
        "lib/flatpickr.min.js",
        "lib/flatpickr.min.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}