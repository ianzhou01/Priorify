{
  "manifest_version": 3,
  "name": "Priorify",
  "description": "A lightweight task prioritization assistant.",
  "version": "1.0",

  "action": {
    "default_popup": "src/popup.html"
  },

  "permissions": ["storage"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}